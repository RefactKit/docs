  "keyFeatures": [
    "Multi-tenant organization workspaces with full data isolation",
    "RBAC with Owner, Admin, and Member roles",
    "OWASP-compliant authentication via Better Auth (email/password + OAuth)",
    "5-language internationalization with RTL support",
    "File uploads via Supabase Storage with server-side security",
    "Type-safe full-stack with TanStack Start, Router, Query, and Form",
    "Vercel, Cloudflare, and Node.js deployment targets via Nitro v3",
    "shadcn/ui design system with Tailwind CSS v4 and dark mode"
  ],
  "publicApiSurface": [
    "signUp.email({ name, email, password })",
    "signIn.email({ email, password })",
    "auth.api.getSession({ headers })",
    "organization.hasPermission({ permission })",
    "createServerFn({ method })",
    "orgBySlugQuery(slug)",
    "getOrgBySlug({ data: { slug } })",
    "uploadFile (storage-fns.ts)",
    "getGalleryImages (gallery-fns.ts)",
    "getDashboardStats (dashboard-fns.ts)",
    "npx drizzle-kit push",
    "npx drizzle-kit studio",
